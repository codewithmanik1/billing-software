generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  name         String   @default("Admin")
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model ShopProfile {
  id        String   @id @default(uuid())
  name      String   @default("More Jewellers")
  tagline   String   @default("Premium Gold & Silver Jewellery")
  phone     String   @default("6281 218 824")
  email     String   @default("morejewellers45@gmail.com")
  address   String   @default("Main Road, Mehkar - 585416, Tq. Bhalki, Dist. Bidar, Karnataka")
  gstin     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shop_profiles")
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  phone     String    @unique
  email     String?
  address   String?
  gstin     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  invoices  Invoice[]
  bishiMembers BishiMember[]

  @@map("customers")
}

model Bishi {
  id               Int           @id @default(autoincrement())
  name             String
  startDate        DateTime
  durationMonths   Int
  monthlyAmount    Decimal       @db.Decimal(10, 2)
  winnersPerMonth  Int           @default(1)
  status           BishiStatus   @default(ACTIVE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  members          BishiMember[]
  payments         BishiPayment[]
  winners          BishiWinner[]

  @@map("bishis")
}

model BishiMember {
  id               Int           @id @default(autoincrement())
  bishiId          Int
  bishi            Bishi         @relation(fields: [bishiId], references: [id], onDelete: Cascade)
  customerId       String
  customer         Customer      @relation(fields: [customerId], references: [id])
  memberNumber     Int
  status           BishiMemberStatus @default(ACTIVE)
  wonMonthNumber   Int?
  wonDate          DateTime?
  joinedAt         DateTime      @default(now())
  payments         BishiPayment[]
  winners          BishiWinner[]

  @@unique([bishiId, customerId])
  @@map("bishi_members")
}

model BishiPayment {
  id                 Int           @id @default(autoincrement())
  bishiId            Int
  bishi              Bishi         @relation(fields: [bishiId], references: [id])
  bishiMemberId      Int
  bishiMember        BishiMember   @relation(fields: [bishiMemberId], references: [id])
  monthNumber        Int
  monthLabel         String
  amountDue          Decimal       @db.Decimal(10, 2)
  dueCarriedForward  Decimal       @db.Decimal(10, 2) @default(0)
  totalPayable       Decimal       @db.Decimal(10, 2)
  amountPaid         Decimal       @db.Decimal(10, 2) @default(0)
  totalOutstanding   Decimal       @db.Decimal(10, 2)
  paymentDate        DateTime?
  status             BishiPaymentStatus @default(PENDING)
  paymentMode        PaymentMode?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("bishi_payments")
}

model BishiWinner {
  id               Int           @id @default(autoincrement())
  bishiId          Int
  bishi            Bishi         @relation(fields: [bishiId], references: [id])
  bishiMemberId    Int
  bishiMember      BishiMember   @relation(fields: [bishiMemberId], references: [id])
  monthNumber      Int
  monthLabel       String
  announcedAt      DateTime      @default(now())
  announcedBy      String

  @@map("bishi_winners")
}

enum BishiStatus {
  ACTIVE
  COMPLETED
}

enum BishiMemberStatus {
  ACTIVE
  WON
}

enum BishiPaymentStatus {
  PAID
  PARTIAL
  DUE
  EXEMPT
  PENDING
}

model Invoice {
  id                   String        @id @default(uuid())
  invoiceNumber        String        @unique
  invoiceDate          DateTime
  dueDate              DateTime?
  customerId           String
  customer             Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items                InvoiceItem[]
  subtotal             Decimal       @db.Decimal(12, 2)
  gstPercent           Decimal       @db.Decimal(5, 2) @default(3)
  gstAmount            Decimal       @db.Decimal(12, 2)
  additionalDiscount   Decimal       @db.Decimal(12, 2) @default(0)
  grandTotal           Decimal       @db.Decimal(12, 2)
  notes                String?
  terms                String?
  status               InvoiceStatus @default(UNPAID)
  payments             Payment[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([customerId])
  @@index([invoiceDate])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id             String   @id @default(uuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description    String
  metalType      String
  weightGrams    Decimal  @db.Decimal(10, 3)
  ratePerGram    Decimal  @db.Decimal(10, 2)
  makingCharges  Decimal  @db.Decimal(10, 2) @default(0)
  discount       Decimal  @db.Decimal(10, 2) @default(0)
  lineTotal      Decimal  @db.Decimal(12, 2)
  sortOrder      Int      @default(0)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id              String      @id @default(uuid())
  invoiceId       String
  invoice         Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  paymentDate     DateTime
  amount          Decimal     @db.Decimal(12, 2)
  paymentMode     PaymentMode
  referenceNumber String?
  notes           String?
  balanceAfter    Decimal     @db.Decimal(12, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([invoiceId])
  @@index([paymentDate])
  @@map("payments")
}

enum InvoiceStatus {
  PAID
  PARTIAL
  UNPAID
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  CARD
  OLD_GOLD
  OLD_SILVER
  FINE_GOLD
  FINE_SILVER
}
